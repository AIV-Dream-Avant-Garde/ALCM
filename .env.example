# ============================================================
# ALCM API Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Database (separate from platform DB)
DATABASE_URL=postgresql+asyncpg://aiv:aiv_password@localhost:5432/alcm_db

# Authentication (must match platform's ALCM_SERVICE_TOKEN)
ALCM_SERVICE_TOKEN=change-this-to-a-secure-random-string

# LLM Provider: "gemini" (dev, cheap) or "claude" (prod, best quality)
LLM_PROVIDER=gemini

# LLM Timeouts (seconds)
LLM_REQUEST_TIMEOUT=60
LLM_STREAM_TIMEOUT=120

# Gemini (default for development — get key at https://makersuite.google.com)
GOOGLE_GENAI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Anthropic/Claude (production — get key at https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-20250514
ANTHROPIC_MODEL_CLASSIFICATION=claude-haiku-4-5-20251001

# Embedding model (uses Google Gemini API — same key as above)
EMBEDDING_MODEL=text-embedding-004

# ElevenLabs (voice synthesis, behind abstraction layer)
ELEVENLABS_API_KEY=

# Storage (S3-compatible, shared with platform or separate)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=alcm-media
MINIO_SECURE=false

# Processing
MAX_CONCURRENT_JOBS=10
JOB_TIMEOUT_SECONDS=300

# Generation
GENERATION_TIMEOUT_SECONDS=30
MAX_PROMPT_TOKENS=27000
MAX_OUTPUT_TOKENS=4000

# Scraping config
MAX_RESEARCH_SNIPPET_LENGTH=2500
